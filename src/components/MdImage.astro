---
import { Image } from "astro:assets";

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
}

let { src, alt, width = 800, height = 0} = Astro.props as Props;
---

<Image
  src={src}
  alt={alt}
  format="avif"
  width={width}
  height={height}
  class={Astro.props.class ? Astro.props.class : "image"}
/>

<style>
  .image {
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 80dvh;
    margin-left: auto;
    margin-right: auto;
    display:block;
  }
</style>
